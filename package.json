{
  "name": "@smsmasivos/mcp-server",
  "version": "1.1.0",
  "description": "MCP server for SMS Masivos — bulk SMS platform for Mexico. 29 tools covering SMS, agendas, contacts, webhooks, reports, payment requests, loyalty, wallet and phone verification (OTP).",
  "type": "module",
  "main": "dist/stdio.js",
  "bin": {
    "smsmasivos-mcp": "dist/stdio.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/stdio.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:eval": "vitest run --config vitest.eval.config.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "sms",
    "smsmasivos",
    "mexico",
    "bulk-sms",
    "model-context-protocol"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/SMS-Masivos/mcp-server.git"
  }
}
